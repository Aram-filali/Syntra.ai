# ============================================================
# Syntra.ai — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================


# ===========================================
# DATABASE
# ===========================================
DB_USER=meeting_user
DB_PASSWORD=meeting_pass
DB_NAME=meeting_intelligence
DATABASE_URL=postgresql://meeting_user:meeting_pass@postgres:5432/meeting_intelligence


# ===========================================
# REDIS (Celery broker & result backend)
# ===========================================
REDIS_PASSWORD=redispass
REDIS_URL=redis://:redispass@redis:6379/0
CELERY_BROKER_URL=redis://:redispass@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redispass@redis:6379/0


# ===========================================
# JWT AUTHENTICATION
# Change JWT_SECRET_KEY to a strong random string in production.
# Minimum 32 characters recommended.
# ===========================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production-32-chars-minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ===========================================
# CORS
# Add your frontend domain here in production.
# ===========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:3000


# ===========================================
# AI / LLM (OpenRouter or OpenAI)
# Get a key at https://openrouter.ai or https://platform.openai.com
# ===========================================
OPENAI_API_KEY=your-openrouter-or-openai-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1


# ===========================================
# TRANSCRIPTION (AssemblyAI)
# Get a free key at https://www.assemblyai.com
# ===========================================
ASSEMBLYAI_API_KEY=your-assemblyai-api-key


# ===========================================
# EMAIL (Brevo SMTP)
# 1. Sign up at https://app.brevo.com
# 2. Go to Settings > SMTP & API
# 3. Create a key and copy the SMTP credentials
# 4. Add your sender email as a validated "Sender" in Brevo
# ===========================================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_login@smtp-brevo.com
SMTP_PASSWORD=your-brevo-smtp-key-starts-with-xsmtpsib
FROM_EMAIL=your-validated-sender@email.com
FROM_NAME=Syntra.ai


# ===========================================
# ZOOM INTEGRATION (optional)
# Get credentials at https://marketplace.zoom.us
# ===========================================
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret
ZOOM_REDIRECT_URI=http://localhost:8000/api/zoom/auth/callback
